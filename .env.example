# Copy to .env and fill in. docker-compose reads these and injects them into
# both the web (app) and db containers. .env is gitignored — never commit secrets.
# Public URL the app builds links against (must match the host port mapping)
PUBLIC_ROOT=http://localhost/public
DB_NAME=giftzone_db
# App's dedicated DB user (NOT root). Created automatically on first db boot.
DB_USER=giftzone
DB_PASSWORD=change-me-app-user
# MySQL admin password — separate secret, not used by the app.
MYSQL_ROOT_PASSWORD=change-me-root
